{
  "name": "elysia-auth-service",
  "module": "index.ts",
  "scripts": {
    "dev": "bun run --hot src/index",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "check": "ultracite check",
    "db:push": "bun run --cwd ./packages/db db:push",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "workspaces": {
    "packages": [
      "service/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.21",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.2",
      "@orpc/client": "^1.12.2",
      "drizzle-orm": "^0.45.1",
      "@types/pg": "^8.16.0"
    }
  },
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@elysia-auth-service/api": "workspace:*",
    "@elysia-auth-service/auth": "workspace:*",
    "@elysia-auth-service/config": "workspace:*",
    "@elysia-auth-service/db": "workspace:*",
    "@elysia-auth-service/env": "workspace:*",
    "@types/bun": "latest",
    "lefthook": "^2.1.3",
    "ultracite": "7.2.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@orpc/openapi": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "@orpc/zod": "^1.13.6",
    "elysia": "^1.4.27",
    "orpc": "^0.1.1"
  }
}
